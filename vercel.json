{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ranky-production.up.railway.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://ranky-production.up.railway.app/auth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
